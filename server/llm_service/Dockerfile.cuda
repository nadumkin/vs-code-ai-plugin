# LLM Service image with CUDA-enabled PyTorch for the hf_local adapter.
# Build/run only on a host with an NVIDIA GPU + nvidia-container-toolkit:
#   docker compose -f docker-compose.yml -f docker-compose.cuda.yml up --build -d
#
# PyTorch 2.7 + CUDA 12.8: native kernels for Ada (RTX 40xx / SM_89) and
# Blackwell (RTX 50xx / SM_120) — no slow PTX-JIT fallback.
FROM pytorch/pytorch:2.7.0-cuda12.8-cudnn9-runtime

WORKDIR /app

# gcc: required at runtime by triton (used by bitsandbytes) to JIT-compile its
# kernel launcher stubs. Plain cc is enough — nvcc is NOT needed for this.
RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc \
    && rm -rf /var/lib/apt/lists/*

COPY llm_service/requirements.txt ./requirements.txt
# torch + CUDA are already in the base image; add service deps + HF stack.
# bitsandbytes: 4-bit NF4 quantization so a 7B model fits a 12 GB card (RTX 4070)
# entirely on-GPU instead of spilling layers to CPU RAM over PCIe.
# Attention uses torch's built-in fused SDPA kernels (see hf_local_adapter);
# the flash-attn package would need nvcc (a '-devel' base image) to build,
# for a marginal gain over SDPA at these model sizes.
RUN pip install --no-cache-dir -r requirements.txt \
    transformers==4.51.3 \
    accelerate==1.7.0 \
    bitsandbytes==0.45.5

COPY common ./common
COPY llm_service ./llm_service

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app
EXPOSE 8002

CMD ["uvicorn", "llm_service.main:app", "--host", "0.0.0.0", "--port", "8002"]

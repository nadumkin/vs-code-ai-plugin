# Copy to ".env" (docker compose reads it automatically): cp .env.example .env

# API key for the openrouter adapter (real models). Leave empty to run fully
# offline with only the "mock/echo" model.
OPENROUTER_KEY=

# The values below already match the docker-compose defaults; uncomment to override.
# DATABASE_URL=postgresql+asyncpg://aiplugin:aiplugin@postgres:5432/aiplugin
# RABBIT_URL=amqp://guest:guest@rabbitmq:5672/
